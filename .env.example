# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Auth ───────────────────────────────────────────────
# Ganti ke managed auth (Clerk/Auth0/WorkOS) sebelum produksi.
JWT_SECRET=change-me-in-production-please-use-a-long-random-string

# ── Database (PostgreSQL + pgvector) ───────────────────
DATABASE_URL=postgres://genesis:genesis@localhost:5432/genesis

# ── Redis (cache + queue) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI Provider (Anthropic Claude) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL_REASONING=claude-opus-4-8
AI_MODEL_CLASSIFY=claude-haiku-4-5-20251001
AI_EMBED_MODEL=voyage-3
# Catatan: embedding bisa pakai provider mana pun; di v1 kita pakai stub deterministik
# bila EMBED_PROVIDER=stub, supaya bisa jalan tanpa kunci embedding.
EMBED_PROVIDER=stub
EMBED_DIM=1024

# ── Agent defaults ─────────────────────────────────────
CONFIDENCE_ESCALATION_THRESHOLD=0.6
